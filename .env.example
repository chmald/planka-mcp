# Planka API Configuration (Required)
PLANKA_BASE_URL=http://localhost:3000
# Recommended: API key auth
PLANKA_API_KEY=your-api-key

# Alternative: username/password auth
PLANKA_USERNAME=your-username
PLANKA_PASSWORD=your-password

# MCP Server Configuration (Optional)
MCP_TRANSPORT=stdio    # "stdio" for single client, "sse" for multiple clients
MCP_PORT=3001          # HTTP port when using SSE transport

# Retry Configuration (Optional)
PLANKA_HTTP_MAX_RETRIES=2         # Retries for transient HTTP/network failures
PLANKA_HTTP_RETRY_BASE_DELAY_MS=250  # Base delay in ms, exponential backoff

# Tool Configuration (Optional)
ENABLE_ALL_TOOLS=false      # Enable all tools (core + admin + optional)
ENABLE_ADMIN_TOOLS=false    # Enable admin tools
ENABLE_OPTIONAL_TOOLS=false # Enable optional tools
